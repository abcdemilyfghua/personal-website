---
import Nav from '../components/Nav.astro';

const { title = "Emily" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <Nav />
    <slot />

    <script>
      // @ts-nocheck
      const colors = ['#d4a8e0','#6fcf97','#b8d96f','#6fb5cf','#cfaa6f','#cf6f6f','#8a8acf','#b06fcf'];
      let colorIndex = 0;

      document.addEventListener('mousemove', (e) => {
        const size = Math.random() * 12 + 6;
        const color = colors[colorIndex % colors.length];
        colorIndex++;

        const c = document.createElement('div');
        c.style.cssText = `
          position:fixed;
          left:${e.clientX}px;
          top:${e.clientY}px;
          width:${size}px;
          height:${size}px;
          border-radius:50%;
          border:2px solid ${color};
          transform:translate(-50%,-50%);
          pointer-events:none;
          z-index:9999;
          transition:opacity 0.5s,transform 0.5s;
        `;
        document.body.appendChild(c);
        requestAnimationFrame(() => {
          c.style.opacity = '0';
          c.style.transform = 'translate(-50%,-50%) scale(2.5)';
        });
        setTimeout(() => c.remove(), 500);
      });
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    -webkit-font-smoothing: antialiased;
  }

  :root {
    --bg: #0f0f0f;
    --text: #e8e8e8;
    --text-muted: rgba(232, 232, 232, 0.6);
    --border: rgba(232, 232, 232, 0.2);
  }

  :root.light {
    --bg: #f9f9f7;
    --text: #111111;
    --text-muted: rgba(17, 17, 17, 0.55);
    --border: rgba(17, 17, 17, 0.15);
  }

  body {
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    transition: background 0.2s, color 0.2s;
  }

  a {
    color: inherit;
  }
</style>

<script>
  const saved = localStorage.getItem('theme');
  if (saved === 'light') document.documentElement.classList.add('light');

  document.addEventListener('click', (e) => {
    if (e.target.closest('.theme-toggle')) {
      const isLight = document.documentElement.classList.toggle('light');
      localStorage.setItem('theme', isLight ? 'light' : 'dark');
    }
  });
</script>