---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Emily — About">
  <main>
    <section class="about">
      <h1>About</h1>
      <p class="bio">[ write a few sentences about yourself here ]</p>

      <div class="section">
        <h2>Experience</h2>
        <div class="entry">
          <div class="entry-header">
            <span class="role">Job Title</span>
            <span class="year">2023 — now</span>
          </div>
          <span class="place">Company or Organization</span>
          <p>What you did there.</p>
        </div>
      </div>

      <div class="section">
        <h2>Education</h2>
        <div class="entry">
          <div class="entry-header">
            <span class="role">Degree</span>
            <span class="year">2019 — 2023</span>
          </div>
          <span class="place">School Name</span>
        </div>
      </div>

      <div class="section">
        <h2>Skills</h2>
        <p class="skills">[ e.g. Python, Figma, Writing, Research ]</p>
      </div>
    </section>
  </main>
</Layout>

<style>
  main {
    max-width: 680px;
    margin: 0 auto;
    padding: 8rem 2rem 4rem;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
  }

  .bio {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--text-muted);
    margin-bottom: 3rem;
  }

  .section {
    margin-bottom: 2.5rem;
  }

  h2 {
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
  }

  .entry {
    margin-bottom: 1.5rem;
  }

  .entry-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 0.2rem;
  }

  .role {
    font-weight: 500;
  }

  .year {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .place {
    font-size: 0.9rem;
    color: var(--text-muted);
    display: block;
    margin-bottom: 0.4rem;
  }

  p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--text-muted);
  }

  .skills {
    line-height: 1.8;
  }
</style>