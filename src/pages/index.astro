---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Emily">
  <main>
    <section class="hero">
      <h1>Hi, I'm Emily.</h1>
      <p class="tagline">Welcome to my website! I'm so glad you're here. I hope you enjoy learning a little more about who I am as a learner, builder, artist, and human experiencing all the beauties of this world.</p>
    </section>
  </main>
</Layout>

<style>
  main {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 2rem;
    padding-top: 6rem;
  }
  .hero {
    max-width: 640px;
  }
  h1 {
    font-size: 3rem;
    margin: 0 0 1rem;
  }
  .tagline {
    font-size: 1.25rem;
    color: var(--text-muted);
  }
</style>