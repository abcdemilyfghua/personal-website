---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categoryColors: Record<string, { bg: string; text: string }> = {
  "Musings":       { bg: "#3d2645", text: "#d4a8e0" },
  "New Territory": { bg: "#1a3a2a", text: "#6fcf97" },
  "Postcards":     { bg: "#2a3a1a", text: "#b8d96f" },
  "Lab Notes":     { bg: "#1a2a3a", text: "#6fb5cf" },
  "Dog-eared":     { bg: "#3a2a1a", text: "#cfaa6f" },
  "Cinema":        { bg: "#1a1a3a", text: "#8a8acf" },
  "Ate That":      { bg: "#3a1a1a", text: "#cf6f6f" },
  "Sidequests":    { bg: "#2a1a3a", text: "#b06fcf" },
};
---

<Layout title="Taken From My Notes App">
  <main>
    <div class="blog-layout">

      <!-- LEFT: FEED -->
      <div class="feed">
        <div class="feed-header">
          <h1>Taken From My Notes App</h1>
          <p class="feed-sub">Everything I felt the need to write down.</p>
        </div>

        <div id="posts-container">
          {posts.map((post) => (
            <article
              class={`post-card ${post.data.featured ? 'featured' : ''}`}
              data-category={post.data.category}
            >
              <div class="card-inner">
                <div class="card-meta">
                  <span
                    class="category-pill"
                    style={`background:${categoryColors[post.data.category]?.bg};color:${categoryColors[post.data.category]?.text}`}
                  >
                    {post.data.category}
                  </span>
                  <span class="date">{post.data.date}</span>
                  <span class="read-time">{post.data.readTime} min read</span>
                </div>
                <h2 class="post-title">
                  <a href={`/blog/${post.id}`}>{post.data.title}</a>
                </h2>
                <p class="excerpt">{post.data.excerpt}</p>
                <a href={`/blog/${post.id}`} class="read-more">Read →</a>
              </div>
            </article>
          ))}
        </div>

        <p class="no-results" id="no-results" style="display:none">
          Nothing here yet. Check back soon.
        </p>
      </div>

      <!-- RIGHT: SIDEBAR -->
      <aside class="sidebar">
        <div class="sidebar-sticky">
          <p class="sidebar-label">Filter by</p>

          <input
            type="text"
            class="search"
            id="search"
            placeholder="Search posts..."
          />

          <div class="category-filters" id="category-filters">
            {Object.entries(categoryColors).map(([cat, colors]) => (
              <button
                class="filter-btn"
                data-category={cat}
                style={`--cat-bg:${colors.bg};--cat-text:${colors.text}`}
              >
                {cat}
              </button>
            ))}
          </div>

          <button class="clear-btn" id="clear-btn" style="display:none">
            Clear filters ✕
          </button>
        </div>
      </aside>

    </div>
  </main>
</Layout>

<style>
  main {
    padding: 7rem 2rem 4rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .blog-layout {
    display: grid;
    grid-template-columns: 1fr 260px;
    gap: 4rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .blog-layout {
      grid-template-columns: 1fr;
    }
    .sidebar { order: -1; }
  }

  .feed-header {
    margin-bottom: 2.5rem;
  }

  h1 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }

  .feed-sub {
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .post-card {
    border-top: 1px solid var(--border);
    padding: 1.75rem 0;
    transition: opacity 0.3s, transform 0.3s;
  }

  .post-card.hidden {
    display: none;
  }

  .post-card.featured .post-title {
    font-size: 1.75rem;
  }

  .post-card.featured .excerpt {
    font-size: 1rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .category-pill {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.65rem;
    border-radius: 999px;
  }

  .date, .read-time {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .post-title {
    font-size: 1.15rem;
    margin-bottom: 0.6rem;
    line-height: 1.4;
  }

  .post-title a {
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .post-title a:hover {
    opacity: 0.7;
  }

  .excerpt {
    font-size: 0.9rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 0.75rem;
  }

  .read-more {
    font-size: 0.85rem;
    text-decoration: none;
    opacity: 0.5;
    transition: opacity 0.2s;
  }

  .read-more:hover {
    opacity: 1;
  }

  .no-results {
    color: var(--text-muted);
    padding: 2rem 0;
    font-size: 0.9rem;
  }

  .sidebar-sticky {
    position: sticky;
    top: 6rem;
  }

  .sidebar-label {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .search {
    width: 100%;
    background: none;
    border: 1px solid var(--border);
    color: var(--text);
    font-family: inherit;
    font-size: 0.85rem;
    padding: 0.6rem 0.9rem;
    border-radius: 8px;
    margin-bottom: 1.25rem;
    outline: none;
    transition: border-color 0.2s;
  }

  .search:focus {
    border-color: var(--text-muted);
  }

  .search::placeholder {
    color: var(--text-muted);
  }

  .category-filters {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .filter-btn {
    background: none;
    border: 1px solid var(--border);
    color: var(--text);
    font-family: inherit;
    font-size: 0.85rem;
    padding: 0.5rem 0.9rem;
    border-radius: 8px;
    cursor: pointer;
    text-align: left;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }

  .filter-btn:hover {
    background: var(--cat-bg);
    color: var(--cat-text);
    border-color: transparent;
  }

  .filter-btn.active {
    background: var(--cat-bg);
    color: var(--cat-text);
    border-color: transparent;
  }

  .clear-btn {
    margin-top: 1rem;
    background: none;
    border: none;
    color: var(--text-muted);
    font-family: inherit;
    font-size: 0.8rem;
    cursor: pointer;
    padding: 0;
    transition: color 0.2s;
  }

  .clear-btn:hover {
    color: var(--text);
  }
</style>

<script>
  const cards = document.querySelectorAll('.post-card');
  const filterBtns = document.querySelectorAll('.filter-btn');
  const clearBtn = document.getElementById('clear-btn');
  const searchInput = document.getElementById('search') as HTMLInputElement;
  const noResults = document.getElementById('no-results');

  let activeCategory = '';
  let searchQuery = '';

  function filterPosts() {
    let visible = 0;

    cards.forEach(card => {
      const cat = card.getAttribute('data-category') || '';
      const title = card.querySelector('.post-title')?.textContent?.toLowerCase() || '';
      const excerpt = card.querySelector('.excerpt')?.textContent?.toLowerCase() || '';

      const matchesCategory = !activeCategory || cat === activeCategory;
      const matchesSearch = !searchQuery || title.includes(searchQuery) || excerpt.includes(searchQuery);

      if (matchesCategory && matchesSearch) {
        card.classList.remove('hidden');
        visible++;
      } else {
        card.classList.add('hidden');
      }
    });

    if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';
    if (clearBtn) clearBtn.style.display = (activeCategory || searchQuery) ? 'block' : 'none';
  }

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const cat = btn.getAttribute('data-category') || '';

      if (activeCategory === cat) {
        activeCategory = '';
        btn.classList.remove('active');
      } else {
        activeCategory = cat;
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
      }

      filterPosts();
    });
  });

  searchInput?.addEventListener('input', () => {
    searchQuery = searchInput.value.toLowerCase().trim();
    filterPosts();
  });

  clearBtn?.addEventListener('click', () => {
    activeCategory = '';
    searchQuery = '';
    searchInput.value = '';
    filterBtns.forEach(b => b.classList.remove('active'));
    filterPosts();
  });
</script>