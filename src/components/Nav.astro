---
---

<nav>
  <a href="/" class="name">Emily</a>
  <div class="nav-right">
    <a href="/projects">Work</a>
    <a href="/blog">Writing</a>
    <a href="/pinned">Pinned</a>
    <a href="/about">About</a>
    <button class="theme-toggle" aria-label="Toggle theme">
      <span class="icon-dark">☀️</span>
      <span class="icon-light">🌙</span>
    </button>
  </div>
</nav>

<style>
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    padding: 1.25rem 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    z-index: 100;
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }

  .name {
    font-weight: 600;
    text-decoration: none;
    font-size: 1rem;
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.75rem;
  }

  .nav-right a {
    text-decoration: none;
    font-size: 0.9rem;
    opacity: 0.7;
    transition: opacity 0.15s;
  }

  .nav-right a:hover {
    opacity: 1;
  }

  .theme-toggle {
    background: none;
    border: 1px solid var(--border);
    color: var(--text);
    width: 2.2rem;
    height: 2.2rem;
    border-radius: 999px;
    cursor: pointer;
    font-size: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .icon-light { display: none; }
  .icon-dark  { display: flex; }

  :global(.light) .icon-light { display: flex; }
  :global(.light) .icon-dark  { display: none; }
</style>
